---
import Main from '../layouts/Main.astro'
import JoinRole from '../components/JoinRole.astro'
import GameInfo from '../components/GameInfo.astro'
import PlayerSelector from '../components/PlayerSelector.astro'
import RoundSelector from '../components/RoundSelector.astro'
import GameControls from '../components/GameControls.astro'
import Rules from '../components/Rules.astro'
import GameBoard from '../components/GameBoard.astro'
import RoundComplete from '../components/RoundComplete.astro'
import Results from '../components/Results.astro'
import '../styles/game-board.css'
import '../styles/game-controls.css'
import '../styles/game-info.css'
import '../styles/game-timer.css'
import '../styles/player-selector.css'
import '../styles/results.css'
import '../styles/round-complete.css'
import '../styles/round-selector.css'
import '../styles/rules.css'
---
<Main title="Penny Game — Simulation Lean">
    <main class="game-container">
        <h1>
            <span class="coin-flip" id="coinFlip">🪙</span>
            Penny Game
        </h1>

        <JoinRole />

        <section id="gameSetup" class="game-setup">
            <GameInfo />
            <PlayerSelector />
            <RoundSelector />
            <GameControls />
            <Rules />
        </section>

        <GameBoard />
        <RoundComplete />
        <Results />
    </main>
    <script type="module" src="/scripts/main.js"></script>
</Main>
