<div class="setup-controls">
    <div class="round-config">
        <h3>⚙️ Configuration</h3>
        <div id="playerCountSection">
            <label>Nombre de joueurs requis :</label>
            <div class="player-count-buttons" id="playerCountButtons">
                <button class="player-count-btn" data-count="2">2</button>
                <button class="player-count-btn" data-count="3">3</button>
                <button class="player-count-btn" data-count="4">4</button>
                <button class="player-count-btn active" data-count="5">5</button>
            </div>
        </div>
        <label>Type de partie :</label>
        <div class="round-count-selector" id="roundCountSelector">
            <div class="round-count-option active" data-type="three_rounds">
                <span class="option-label">3 Manches</span>
                <span class="option-desc">Lots de 15 → 5 → 1</span>
            </div>
            <div class="round-count-option" data-type="two_rounds">
                <span class="option-label">2 Manches</span>
                <span class="option-desc">Lots de 15 → 1</span>
            </div>
            <div class="round-count-option" data-type="single">
                <span class="option-label">1 Manche</span>
                <span class="option-desc">Lot au choix</span>
            </div>
        </div>
        <div id="singleBatchSelector" class="batch-selector" style="display: none;">
            <label>Taille de lot :</label>
            <div class="batch-options">
                <div class="batch-option" data-size="1">1</div>
                <div class="batch-option" data-size="3">3</div>
                <div class="batch-option" data-size="5">5</div>
                <div class="batch-option active" data-size="15">15</div>
            </div>
        </div>
    </div>
</div>
