<section id="results" class="results-section" style="display: none;">
    <h2>🏆 Résultats de la Partie</h2>
    <div class="game-time-section">
        <div class="game-time-label">Temps total de jeu</div>
        <div class="game-time-value" id="gameTimeValue">--:--</div>
    </div>
    <div class="stats-grid" id="statsGrid"></div>
    <div class="player-timers-section">
        <h3>👥 Performance des Joueurs</h3>
        <div class="player-timers-grid" id="playerTimersGrid"></div>
    </div>
    <div class="insights">
        <h3>💡 Enseignements Lean</h3>
        <ul id="insightsList"></ul>
    </div>
    <div class="results-actions" id="resultsActions" style="display: none;">
        <button class="btn btn-primary" id="playAgainBtn">🔄 Rejouer</button>
        <button class="btn btn-secondary" id="backToLobbyBtn">🏠 Retour au Lobby</button>
    </div>
</section>
