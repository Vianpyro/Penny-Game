<section id="roundComplete" class="round-complete-section" style="display: none;">
    <h2>✅ Manche <span id="completedRoundNumber">1</span> Terminée !</h2>
    <div class="round-summary">
        <div class="round-stat"><span class="stat-label">Taille de lot :</span><span class="stat-value" id="completedBatchSize">--</span></div>
        <div class="round-stat"><span class="stat-label">Temps :</span><span class="stat-value" id="completedRoundTime">--:--</span></div>
        <div class="round-stat"><span class="stat-label">Lead Time :</span><span class="stat-value" id="completedLeadTime">--:--</span></div>
    </div>
    <div class="round-stats-detail">
        <div class="stat-item"><span class="stat-label">Pièces complétées :</span><span id="totalCoinsCompleted">15</span></div>
        <div class="stat-item"><span class="stat-label">Participants :</span><span id="participantCount">--</span></div>
        <div class="stat-item"><span class="stat-label">Efficacité :</span><span id="roundEfficiency">--</span> pièces/min</div>
        <div class="stat-item"><span class="stat-label">Lead Time :</span><span id="roundLeadTime">--:--</span></div>
        <div class="stat-item"><span class="stat-label">Temps moyen/joueur :</span><span id="avgPlayerTime">--:--</span></div>
    </div>
    <div class="player-timers-grid" id="roundPlayerTimersGrid"></div>
    <div class="round-progress" id="roundProgressBar"></div>
    <div class="progress-label">Manche <span id="currentProgressRound">1</span> / <span id="totalProgressRounds">3</span></div>
    <div id="nextRoundSection" style="display: none;">
        <p>Prochaine manche : lot de <strong id="nextBatchSizeDesc">--</strong></p>
        <button class="btn btn-primary" id="nextRoundBtn">🚀 Démarrer Manche <span id="nextRoundButtonNumber">2</span></button>
    </div>
    <div id="gameCompleteSection" style="display: none;">
        <p>Toutes les manches sont terminées !</p>
        <button class="btn btn-primary" id="viewResultsBtn">📊 Voir les Résultats</button>
    </div>
</section>
